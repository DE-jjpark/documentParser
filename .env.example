# 이 파일을 .env.local로 복사해서 토큰/키만 채워 넣으면 된다.
# (.env.local은 .gitignore에 있어서 커밋되지 않는다.)

# --- Databricks AI Gateway (VLM: 그림/표 캡션) ---
# 워크스페이스 호스트 -- 비밀 아님, 팀 공용 값 그대로 둬도 된다.
DATABRICKS_HOST=adb-1017423463570685.5.azuredatabricks.net
# model-serving + ai-gateway 스코프가 있는 개인 토큰 -- 비워두고 각자 채울 것.
DATABRICKS_TOKEN=

# --- Azure Document Intelligence (표 구조 추출) ---
# 리소스 엔드포인트 -- 비밀 아님.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://rnd-skep-commpf-di.cognitiveservices.azure.com/
# 리소스 키 -- 비워두고 각자 채울 것.
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- LangSmith 트레이싱(선택) ---
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=SKEP_PARSER
# LangSmith API 키 -- 비워두고 각자 채울 것.
LANGSMITH_API_KEY=
